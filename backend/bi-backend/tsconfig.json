{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2017",

    "outDir": "./dist",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "sourceMap": true,

    "incremental": true,
    "skipLibCheck": true,

    "strictNullChecks": false,
    "noImplicitAny": false,

    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,

    "types": ["node", "jest"]
  },

  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}